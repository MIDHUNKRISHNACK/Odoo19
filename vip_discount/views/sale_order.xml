<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <data>

        <record id="sale_order_vip_discount_inherit_view" model="ir.ui.view">
            <field name="name">sale.order.vip.discount.inherit.view</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='payment_term_id']" position="after">
                   <field name="vip_discount"/>
                     <field name="is_vip_discount_apply" />
                </xpath>


            </field>
        </record>
 </data>
</odoo>