<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--   tree view-->
         <record model="ir.ui.view" id="machine_transfer_tree_views">
            <field name="name">machine.machine.tree</field>
            <field name="model">machine.machine.transfer</field>
            <field name="arch" type="xml">
                <list>

                    <field name="machine_name_id"/>
                    <field name="transfer_type"/>
                    <field name="customer_name_id"/>
                </list>
            </field>
        </record>

    <!--    Form View-->
    <record id="machine_transfer_forms_views" model="ir.ui.view">
        <field name="name">machines.transfer.form</field>
        <field name="model">machine.machine.transfer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                     <button name="button_transfer" type="object" string="Transfer" class="oe_highlight" invisible="transfer_ribbon_id"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" text="Transfered" bg_color="text-bg-danger" invisible="not transfer_ribbon_id"/>
                    <div class="oe_title">
                        <h1>
                            <field name="machine_name_id"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="serial_number_id"/>
                            <field name="transfer_date"/>
                        </group>

                        <group>
                            <field name="customer_name_id" invisible="transfer_type =='remove'"/>
                            <field name="company_id"/>
                            <field name="transfer_type" />
                        </group>
                    </group>
                     <group>
                        <notebook>
                            <page string="Instructions" name="instructions">
                                <field name="instructions" placeholder="Add a description..."
                                       />
                            </page>
                        </notebook>
                    </group>

                </sheet>


                <chatter/>
            </form>
        </field>
    </record>


    <!--    default-->
    <record id="machine_transfer_actions" model="ir.actions.act_window">
        <field name="name">Machine transfer action</field>
        <field name="res_model">machine.machine.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create Your First Machine</p>
        </field>
    </record>

</odoo>