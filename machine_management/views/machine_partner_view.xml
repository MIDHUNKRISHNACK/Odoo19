<?xml version="1.0" encoding="utf-8"?>
<odoo>

     <record id="customer_search_view" model="ir.ui.view">
    <field name="name">customer Search</field>
   <field name="model">res.partner</field>
   <field name="arch" type="xml">
       <search>

               <filter name="filter_status_archieve" string="Archieved" domain="[('active','=',False)]"/>
             <group name="group_filters">
                 <filter string="Employee" name="employee" context="{'group_by': 'id'}"/>
             </group>
       </search>
   </field>
</record>



<record id="machine_customer_actions" model="ir.actions.act_window">
        <field name="name" >Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain"/>
        <field name="context">{"search_default_filter_status_archieve":1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create Your First Machine</p>
        </field>
    </record>


</odoo>