<?xml version="1.0" encoding="utf-8"?>
<odoo>


<!--    tree view-->
     <record model="ir.ui.view" id="machine_service_tree_views">
        <field name="name">machine.service.tree</field>
        <field name="model">machine.machine.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="machine_id"/>
                <field name="customer_id"/>
                <field name="date_of_service"/>
                <field name="service_state"/>
                <field name="tech_person_id"/>
            </list>
        </field>
    </record>


<!--    Form View-->
     <record model="ir.ui.view" id="machine_service_forms_views">
        <field name="name">machines.service.form</field>
        <field name="model">machine.machine.service</field>
        <field name="arch" type="xml">
            <form delete="True">
                <header>
                    <button name="button_case_start" type="object" string="Start" class="oe_highlight" invisible="is_case_status == True"/>
                    <button name="button_case_close" type="object" string="Close" class="oe_highlight"/>
                     <button name="machine_invoice" type="object" string="Invoice" invisible="is_case_status == False" class="oe_highlight"/>
                     <field name="service_state" widget="statusbar" options="{'clickable':1}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                          <button class="oe_stat_button" type="object"
                            name="action_open_invoice"
                            icon="fa-usd" invisible="not is_ribbon_status">
                              <div class="o_stat_info">
                            <span class="o_stat_text">Invoice</span>
                              </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" text="Invoiced" bg_color="text-bg-danger" invisible="not is_ribbon_status"/>
                    <widget name="web_ribbon" text="Draft" bg_color="text-bg-danger" invisible="not is_ribbon_draft"/>
                    <widget name="web_ribbon" text="Paid" bg_color="text-bg-danger" invisible="not is_ribbon_paid"/>
                    <div class="oe_title">
                        <h1>
                            <field name="machine_id" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="date_of_service"/>
                        </group>

                        <group>
                            <field name="is_ribbon_draft"/>
                            <field name="is_ribbon_paid"/>
                             <field name="company_id"/>
                            <field name="tech_person_id"/>

                        </group>
                    </group>

                    <group>
                        <notebook>
                            <page string="Consumed Parts" name="consumed_parts">
                                <field name="consumed_parts_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="part_quantity"/>
                                    <field name="part_price"/>
                                    <field name="part_uom"/>
                                </list>
                                </field>

                            </page>
                            <page string="Service Descriptions" name="descriptions">

                                <field name="service_description"/>

                            </page>
                            <page string="Internal Note" name="internal_note">

                                <field name="internal_note" />

                            </page>
                        </notebook>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>


<!--    default-->
     <record id="machine_service_actions" model="ir.actions.act_window">
        <field name="name">Machine Services</field>
        <field name="res_model">machine.machine.service</field>
        <field name="view_mode">list,form</field>
     </record>


</odoo>