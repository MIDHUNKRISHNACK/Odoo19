<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
         <record id="module_category_machines" model="ir.module.category">
            <field name="name">Machine_management</field>
            <field name="description">Manage Machine Services</field>
            <field name="sequence">10</field>
        </record>
         <record model="res.groups.privilege" id="res_groups_privilege_machines">
            <field name="name">Machine_management</field>
            <field name="sequence">18</field>
            <field name="category_id" ref="machine_management.module_category_machines"/>
        </record>

        <record id="group_machine_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_machines"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">the user will have access to his machines data in machine_management Application.</field>
        </record>
        <record id="group_machine_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_machines"/>
            <field name="implied_ids" eval="[(4, ref('machine_management.group_machine_user'))]"/>
            <field name="comment">the manager will have access to all machines data in machine_management Application.</field>
        </record>
