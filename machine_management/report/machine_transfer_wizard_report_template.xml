<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="transfer_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <h2 class="text-center">Machine Transfer Report</h2>
                    <hr/>

                    <div class="row mb-4">

                        <div class="col-3">
                            <strong>From:</strong>
                            <span t-esc="data[-1]['from_date']"/>
                        </div>
                        <t t-if="is_unique_name==True">
                            <div class="col-6">
                                <strong>Customer Name :</strong>
                                <span t-esc="cus_name"/>
                            </div>
                        </t>

                    </div>
                </div>
                <div class="row mb-4">
                    <div class="col-3">
                        <strong>To:</strong>
                        <span t-esc="data[-1]['to_date']"/>
                    </div>

                </div>
                <t t-if="is_unique_name==True">
                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th>
                                    <strong>Machine Name</strong>
                                </th>

                                <th>
                                    <strong>Due Date</strong>
                                </th>
                                <th>
                                    <strong>Transfer Type</strong>
                                </th>

                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data" t-as="transfer">
                                <tr>
                                    <t t-if="len(transfer)==4">
                                        <td t-esc="transfer['machine_name']"/>
                                        <td t-esc="transfer['transfer_date']"/>
                                        <td t-esc="transfer['transfer_type'].capitalize()"/>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-if="is_unique_name==False">
                <table class="table table-bordered table-sm">
                    <thead class="table-primary">
                        <tr>
                            <th>
                                <strong>Machine Name</strong>
                            </th>
                            <th>
                                <strong>Customer Name</strong>
                            </th>
                            <th>
                                <strong>Due Date</strong>
                            </th>
                            <th>
                                <strong>Transfer Type</strong>
                            </th>

                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="data" t-as="transfer">
                            <tr>
                                <t t-if="len(transfer)==4">
                                    <td t-esc="transfer['machine_name']"/>
                                    <td t-esc="transfer['name']"/>
                                    <td t-esc="transfer['transfer_date']"/>
                                    <td t-esc="transfer['transfer_type'].capitalize()"/>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>
                </t>
                <div class="mt-3">
                    <strong>Total Transfers:</strong>
                    <span t-esc="len_transfer_ids"/>
                </div>

        </t>
    </t>
</template>
        </odoo>