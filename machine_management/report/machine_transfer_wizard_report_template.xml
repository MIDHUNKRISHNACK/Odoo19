<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="transfer_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <h2 class="text-center">Machine Transfer Report</h2>
                    <hr/>
                    <div class="row mb-4">
                        <div class="col-6">
                            <strong>Machine name </strong>
                            <t t-foreach="data" t-as="machine_name">
                            <span t-esc="machine_name.machine_name"/>
                            </t>
                        </div>
<!--                        <div class="col-3">-->
<!--                            <strong>From: </strong>-->
<!--                            <span t-esc="transfer_ids.from_date"/>-->
<!--                        </div>-->
                        </div>
                    <div class="row mb-4">
                         <div class="col-6">
                            <strong>Customer Name : </strong>
                             <t t-foreach="data" t-as="customer_id">
                            <span t-esc="customer_id.name"/>
                            </t>

                        </div>
<!--                        <div class="col-3">-->
<!--                            <strong>To: </strong>-->
<!--                            <span t-esc="to_date"/>-->
<!--                        </div>-->

                    </div>
                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th>
                                    <strong>Machine Name</strong>
                                </th>
                                <th>
                                     <strong>Customer Name</strong>
                                </th>
                                <th>
                                     <strong>Due Date</strong>
                                </th>
                                <th>
                                <strong> Transfer Type </strong>
                                </th>

                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data" t-as="transfer">
                                <tr>

                                    <td t-esc="transfer.machine_name_id.machine_name"/>
                                    <td t-esc="transfer.res_partner_id.name"/>
                                    <td t-esc="transfer.transfer_date"/>
                                    <td t-esc="transfer.transfer_type"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <div class="mt-3">
                        <strong>Total Transfers: </strong>
                        <span t-esc="len(data)"/>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>